# ======================================================================
# SolarDryerAI — .env PRODUKSI (dipakai `./run.sh deploy` di server trin)
# Secret kosong (APP_KEY, REVERB_*, AI_WEBHOOK_KEY, IOT_DEVICE_KEY) akan
# di-generate otomatis oleh run.sh. WAJIB isi manual: ADMIN_*, GEMINI_API_KEY,
# GROQ_API_KEY, OPENWEATHER_API_KEY.
# ======================================================================

APP_NAME="Padi PRECISION"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://solardryer.trin-polman.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Log ke stderr → terlihat via `./run.sh prod-logs`
LOG_CHANNEL=stderr
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

# ── Database: SQLite di volume docker (/data) ─────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Produksi di belakang Cloudflare (HTTPS) → cookie secure
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@trin-polman.id"
MAIL_FROM_NAME="${APP_NAME}"

# ── Port host (bind 127.0.0.1; publik via Cloudflare Tunnel) ──────────
# 8088/33061 sudah dipakai koperasi-app di server trin — jangan bentrok.
WEB_PORT=8097
N8N_PORT=5681
TZ=Asia/Jakarta

# ── Admin produksi (WAJIB GANTI — dipakai EssentialSeeder saat pertama) ──
ADMIN_NAME="Administrator"
ADMIN_EMAIL=admin@trin-polman.id
ADMIN_PASSWORD=GANTI-password-admin-ini

# ── Laravel Reverb (WebSocket dashboard) ──────────────────────────────
# REVERB_HOST = alamat INTERNAL container (Laravel → reverb). Jangan diubah.
REVERB_APP_ID=solardryer
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Client (browser). Kosong = otomatis ikut domain halaman (disarankan —
# WS diproksikan Apache di path /app, jadi cukup same-origin).
REVERB_CLIENT_HOST=
REVERB_CLIENT_PORT=
REVERB_CLIENT_SCHEME=

# ── AI & Cuaca (WAJIB isi untuk fitur AI) ─────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
OPENWEATHER_API_KEY=
OPENWEATHER_LAT=-7.0271
OPENWEATHER_LON=107.5892

# ── API key proteksi endpoint publik (digenerate run.sh bila kosong) ──
# AI_WEBHOOK_KEY  : header X-AI-Webhook-Key (n8n → /api/ai/*)
# IOT_DEVICE_KEY  : header X-Device-Key (ESP32 → /api/iot/*) — samakan
#                   dengan DEVICE_KEY di esp32_solardryerai.ino
AI_WEBHOOK_KEY=
IOT_DEVICE_KEY=
