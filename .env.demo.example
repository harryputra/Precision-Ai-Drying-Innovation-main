# ======================================================================
# SolarDryerAI — .env DEMO (dipakai `./run.sh` / `./run.sh demo`)
# Stack terpisah dari produksi (COMPOSE_PROJECT_NAME solardryer-demo,
# volume & port sendiri). Berisi data contoh + Quick-Login aktif.
# ======================================================================

APP_NAME="Padi PRECISION (Demo)"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8098

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="demo@solardryerai.test"
MAIL_FROM_NAME="${APP_NAME}"

# Port host demo — beda dari produksi (8097/5681) agar bisa jalan bersamaan
WEB_PORT=8098
N8N_PORT=5682
TZ=Asia/Jakarta

# Admin demo (EssentialSeeder) — akun contoh lain dibuat DemoSeeder
ADMIN_NAME="Ihsan Alfarisi"
ADMIN_EMAIL=admin@solardryerai.test
ADMIN_PASSWORD=password

REVERB_APP_ID=solardryer-demo
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_CLIENT_HOST=
REVERB_CLIENT_PORT=
REVERB_CLIENT_SCHEME=

# AI & cuaca — boleh kosong untuk demo (fitur AI manual akan nonaktif)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
OPENWEATHER_API_KEY=
OPENWEATHER_LAT=-7.0271
OPENWEATHER_LON=107.5892

AI_WEBHOOK_KEY=
IOT_DEVICE_KEY=
